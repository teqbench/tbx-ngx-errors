{
  "$schema": "./node_modules/ng-packagr/ng-package.schema.json",
  "dest": "dist",
  "lib": {
    "entryFile": "src/index.ts"
  },
  "assets": [
    {
      "input": "docs",
      "glob": "*.{md,yml}",
      "output": "docs"
    },
    {
      "input": ".",
      "glob": "CHANGELOG.md",
      "output": "."
    }
  ]
}
